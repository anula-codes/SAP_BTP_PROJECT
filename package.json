{
  "name": "novabuild-p2p-analytics",
  "version": "1.0.0",
  "description": "NovaBuild P2P Analytics Service — SAP CAP Backend Developer Capstone Project",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "cds-serve",
    "dev": "cds watch",
    "build": "cds build --production",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand --forceExit",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "deploy:hana": "cds deploy --to hana",
    "mta:build": "mbt build -p=cf"
  },
  "dependencies": {
    "@cap-js/sqlite": "^2.2.0",
    "@sap/cds": "^9.8.5",
    "@sap/xssec": "^3.6.0",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.6",
    "express": "^4.18.2",
    "hdb": "^0.19.9",
    "passport": "^0.7.0"
  },
  "devDependencies": {
    "@sap/cds-dk": "^9.8.4",
    "axios": "^1.7.2",
    "better-sqlite3": "^9.4.3",
    "eslint": "^8.57.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/test/**/*.test.js"
    ],
    "testTimeout": 30000,
    "collectCoverageFrom": [
      "srv/**/*.js"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 50,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    }
  },
  "cds": {
    "requires": {
      "db": {
        "kind": "sqlite",
        "credentials": {
          "database": ":memory:"
        }
      },
      "[production]": {
        "db": {
          "kind": "hana-cloud"
        },
        "auth": {
          "kind": "xsuaa"
        }
      },
      "[development]": {
        "auth": {
          "kind": "mocked",
          "users": {
            "alice": {
              "roles": [
                "P2PApprover",
                "P2PViewer"
              ]
            },
            "bob": {
              "roles": [
                "P2PViewer"
              ]
            },
            "carol": {
              "roles": []
            }
          }
        }
      }
    },
    "features": {
      "fiori_preview": true,
      "odata_new_parser": true
    }
  }
}
